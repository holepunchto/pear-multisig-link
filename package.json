{
  "name": "pear-multisig-link",
  "version": "1.0.0",
  "main": "index.js",
  "type": "commonjs",
  "description": "Deterministic multisig link per multisig inputs",
  "license": "Apache-2.0",
  "files": [],
  "bin": "bin.js",
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
